---
// src/components/Hero.astro
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/seo';

interface Props {
  featured: CollectionEntry<'articles'> & { data: { slug: string } };
  sidebar: (CollectionEntry<'articles'> & { data: { slug: string } })[];
}

const { featured, sidebar } = Astro.props;
const f = featured.data;
---

<section class="hero-section" aria-label="Featured story">

  <!-- MAIN FEATURED -->
  <a href={`/articulo/${f.slug}`} class="hero-main" aria-label={`Read: ${f.title}`}>
    <img
      src={f.image}
      alt={f.imageAlt}
      class="hero-img"
      width="900"
      height="500"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay">
      <div class="hero-meta-top">
        {f.badge && (
          <span class={`badge badge-${f.badge}`}>{f.badge}</span>
        )}
        <span class="cat-label">{f.category}</span>
      </div>
      <div class="hero-kicker" aria-hidden="true">
        <span class="kicker-line"></span>
        <span class="kicker-text" data-en="Featured Analysis" data-es="Análisis Destacado">Featured Analysis</span>
      </div>
      <h1 class="hero-title">
        {f.title}
      </h1>
      <p class="hero-excerpt">{f.excerpt}</p>
      <div class="hero-footer">
        <span class="hero-byline">
          {f.author}{f.authorTitle && `, ${f.authorTitle}`} · {formatDate(f.date)}
          {f.readingTime && ` · ${f.readingTime} min read`}
        </span>
        <span class="hero-cta" data-en="Read Full Story →" data-es="Leer Historia →">Read Full Story →</span>
      </div>
    </div>
  </a>

  <!-- SIDEBAR STORIES -->
  <aside class="hero-side" aria-label="Top stories">
    <div class="side-hdr" data-en="Top Stories" data-es="Principales Historias">Top Stories</div>
    {sidebar.map((art) => (
      <a href={`/articulo/${art.data.slug}`} class="side-card" aria-label={`Read: ${art.data.title}`}>
        <img
          src={art.data.image}
          alt={art.data.imageAlt}
          class="side-thumb"
          width="80"
          height="62"
          loading="lazy"
        />
        <div class="side-content">
          <div class="side-cat">{art.data.category}</div>
          <div class="side-ttl">{art.data.title}</div>
          <div class="side-time">{formatDate(art.data.date)}</div>
        </div>
      </a>
    ))}
  </aside>

</section>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 1px;
    background: var(--border-subtle);
    border: 1px solid var(--border-subtle);
    margin-top: 28px;
    margin-bottom: 0;
  }

  /* MAIN */
  .hero-main {
    position: relative;
    overflow: hidden;
    min-height: 500px;
    background: var(--black-mid);
    display: block;
    cursor: pointer;
  }
  .hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.5s;
    filter: brightness(0.55) saturate(0.8);
  }
  .hero-main:hover .hero-img {
    transform: scale(1.03);
    filter: brightness(0.6) saturate(1);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top,
      rgba(5,7,16,0.97) 0%,
      rgba(5,7,16,0.7) 50%,
      rgba(5,7,16,0.1) 85%,
      transparent 100%
    );
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 36px 40px;
  }
  .hero-meta-top {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 14px;
  }
  .hero-kicker {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 12px;
  }
  .kicker-line {
    width: 24px; height: 1px;
    background: var(--cyan);
  }
  .kicker-text {
    font-family: var(--font-mono);
    font-size: 10px; letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: 40px; font-weight: normal;
    color: white; line-height: 1.1;
    margin-bottom: 14px;
    transition: color 0.2s;
  }
  .hero-main:hover .hero-title { color: var(--cyan); }
  .hero-excerpt {
    font-family: var(--font-body);
    font-size: 15px; color: rgba(240,244,255,0.6);
    line-height: 1.65; margin-bottom: 20px;
    max-width: 560px;
  }
  .hero-footer {
    display: flex; align-items: center;
    justify-content: space-between; gap: 16px;
    flex-wrap: wrap;
  }
  .hero-byline {
    font-family: var(--font-mono);
    font-size: 11px; color: rgba(255,255,255,0.4);
  }
  .hero-cta {
    font-family: var(--font-mono);
    font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid rgba(0,212,255,0.4);
    padding: 7px 18px;
    transition: all 0.2s;
  }
  .hero-main:hover .hero-cta {
    background: var(--cyan); color: var(--black);
    border-color: var(--cyan);
  }

  /* SIDE */
  .hero-side {
    background: var(--black-card);
    display: flex; flex-direction: column;
  }
  .side-hdr {
    padding: 12px 18px;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 9px; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
    background: var(--black-ele);
    display: flex; align-items: center; gap: 8px;
  }
  .side-hdr::before { content: '▸'; }
  .side-card {
    display: flex; gap: 12px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border-subtle);
    cursor: pointer; text-decoration: none; color: inherit;
    transition: background 0.15s;
  }
  .side-card:last-child { border-bottom: none; }
  .side-card:hover { background: var(--black-ele); }
  .side-thumb {
    width: 78px; height: 60px;
    object-fit: cover; flex-shrink: 0;
    filter: grayscale(30%);
    transition: filter 0.3s;
  }
  .side-card:hover .side-thumb { filter: grayscale(0); }
  .side-content { flex: 1; min-width: 0; }
  .side-cat {
    font-family: var(--font-mono);
    font-size: 8.5px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--cyan);
    margin-bottom: 4px;
  }
  .side-ttl {
    font-family: var(--font-display);
    font-size: 14px; font-weight: normal;
    line-height: 1.3; color: var(--white);
    transition: color 0.2s;
  }
  .side-card:hover .side-ttl { color: var(--cyan); }
  .side-time {
    font-family: var(--font-mono);
    font-size: 9.5px; color: var(--white-mute);
    margin-top: 5px;
  }

  @media (max-width: 900px) {
    .hero-section { grid-template-columns: 1fr; }
    .hero-main { min-height: 400px; }
    .hero-title { font-size: 28px; }
    .hero-side { display: grid; grid-template-columns: repeat(2, 1fr); }
    .side-hdr { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .hero-overlay { padding: 24px 20px; }
    .hero-title { font-size: 22px; }
    .hero-side { grid-template-columns: 1fr; }
  }
</style>
