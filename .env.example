# NeuralPulse Environment Variables
# Copy this file to .env and fill in your values

# Google AdSense Publisher ID
PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# AdSense Slot IDs (comma-separated, in order: leaderboard, sidebar, in-article, footer)
PUBLIC_ADSENSE_SLOTS=1111111111,2222222222,3333333333,4444444444

# Site URL (no trailing slash)
PUBLIC_SITE_URL=https://neuralpulse.io

# Newsletter API (optional - Mailchimp, ConvertKit, etc.)
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
